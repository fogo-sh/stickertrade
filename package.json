{
  "name": "stickertrade",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import remix/node-tsx server.ts",
    "start": "node --import remix/node-tsx server.ts",
    "test": "NODE_ENV=test node --import remix/node-tsx --test 'test/**/*.test.ts' 'test/**/*.test.tsx'",
    "typecheck": "tsc --noEmit",
    "migrate": "node --import remix/node-tsx scripts/migrate.ts",
    "seed": "node --import remix/node-tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=24.3.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "feed": "^5.1.0",
    "front-matter": "^4.0.2",
    "marked": "^14.1.3",
    "remix": "^3.0.0-beta.2",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
